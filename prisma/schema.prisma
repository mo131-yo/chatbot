generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model product {
    id          Int      @id @default(autoincrement())
    name        String
    description String
    price       Float
    imageUrl    String
    stock       Int
    color       String
    size        String
    rating      Float
    reviews     Int
    category    String
    brand       String

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}
