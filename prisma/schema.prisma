generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  STORE_OWNER
}

enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  HIDDEN
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  QPAY
  SOCIALPAY
  CASH
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String?  @unique
  password    String?
  name        String?
  imageUrl    String?
  role        UserRole @default(USER)

  cart   Cart?
  orders Order[]
  chats  ChatSession[]
  stores Store[]
  favorites Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String?
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  
  isPinned  Boolean       @default(false)
  isPublic  Boolean       @default(false)
  
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, isPinned])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  role          ChatRole
  content       String
  imagePreview  String?     @db.Text 
  createdAt     DateTime    @default(now())

  @@index([chatSessionId, createdAt])
}

model Store {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products  Product[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String?   @unique
  description   String?
  price         Float
  discountPrice Float?
  brand         String?
  images        String[]
  subcategory   String?
  colors        String[]
  sizes         String[]
  tags          String[]
  categoryName  String?
  stock         Int      @default(0)
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  isFeatured    Boolean  @default(false)
  isTrending    Boolean  @default(false)
  status        ProductStatus @default(AVAILABLE)

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])

  cartItems  CartItem[]
  // orderItems OrderItem[]
  // orders     Order[]
  favorites Favorite[]
  // embedding  ProductEmbedding?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productEmbedding ProductEmbedding?


  @@index([storeId])
  @@index([categoryId])
  @@index([status])
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String?   @unique
  products Product[] 
}

model Cart {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     CartItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id String @id @default(uuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int      @default(1)
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  productName  String?
  productImage String?
  // product   Product @relation(fields: [productId], references: [id])

  storeId String?
  store   Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  quantity      Int     @default(1)
  price         Float
  paidAt    DateTime?

  customerName  String?
  customerPhone String
  address       String?


  totalAmount Float
  status      OrderStatus @default(PENDING)

  items     OrderItem[]
  payment   Payment?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([storeId])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  // product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  productName  String?
  productImage String?
  
  quantity Int
  price    Float

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  transactionId String?
  method        PaymentMethod
  amount        Float
  status        PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductEmbedding {
  id String @id @default(uuid())

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  pineconeId String @unique
  content    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}